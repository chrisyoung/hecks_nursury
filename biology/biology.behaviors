Hecks.behaviors "Biology" do
  vision "Behavioral tests for the Biology domain — exercises every command and query in memory"

  # ── Cell aggregate ──────────────────────────────────────────

  test "CultureCell sets name + organism_type" do
    tests "CultureCell", on: "Cell"
    input  name: "sample", organism_type: "sample"
    expect cell_type: "stem", name: "sample", organism_type: "sample", membrane_integrity: 1.0, energy_level: 100.0, phase: "interphase"
  end

  test "Divide cascades through policy chain" do
    tests "Divide", on: "Cell", kind: :cascade
    setup  "CultureCell", name: "sample", organism_type: "sample"
    input  division_type: "sample"
    expect emits: ["CellDivided", "CellMetabolized"]
  end

  test "Differentiate sets target_type + signals" do
    tests "Differentiate", on: "Cell"
    setup  "CultureCell", name: "sample", organism_type: "sample"
    input  target_type: "sample", signals: "sample"
    expect differentiation_state: "sample", cell_type: "sample"
  end

  test "Metabolize sets pathway + substrate" do
    tests "Metabolize", on: "Cell"
    setup  "CultureCell", name: "sample", organism_type: "sample"
    input  pathway: "sample", substrate: "sample"
    expect ok: "true"
  end

  test "TriggerApoptosis runs" do
    tests "TriggerApoptosis", on: "Cell"
    setup  "CultureCell", name: "sample", organism_type: "sample"
    expect membrane_integrity: 0.0, phase: "apoptotic"
  end

  test "EnterPhase runs" do
    tests "EnterPhase", on: "Cell"
    setup  "CultureCell", name: "sample", organism_type: "sample"
    expect phase: "G1"
  end

  test "RepairMembrane sets integrity" do
    tests "RepairMembrane", on: "Cell"
    setup  "CultureCell", name: "sample", organism_type: "sample"
    input  integrity: 1.0
    expect membrane_integrity: 1.0
  end


  # ── DNA aggregate ──────────────────────────────────────────

  test "SequenceDNA sets sequence + organism + strand_type" do
    tests "SequenceDNA", on: "DNA"
    input  sequence: "sample", organism: "sample", strand_type: "sample"
    expect sequence: "sample", organism: "sample", strand_type: "sample", integrity: 1.0
  end

  test "Transcribe sets gene_name + promoter" do
    tests "Transcribe", on: "DNA"
    setup  "SequenceDNA", sequence: "sample", organism: "sample", strand_type: "sample"
    input  gene_name: "sample", promoter: "sample"
    expect ok: "true"
  end

  test "Mutate sets mutation_type + position + original_base + new_base" do
    tests "Mutate", on: "DNA"
    setup  "SequenceDNA", sequence: "sample", organism: "sample", strand_type: "sample"
    input  mutation_type: "sample", position: 1, original_base: "sample", new_base: "sample"
    expect ok: "true"
  end

  test "Mutate cascades through policy chain" do
    tests "Mutate", on: "DNA", kind: :cascade
    setup  "SequenceDNA", sequence: "sample", organism: "sample", strand_type: "sample"
    input  mutation_type: "sample", position: 1, original_base: "sample", new_base: "sample"
    expect emits: ["DNAMutated", "DNARepaired"]
  end

  test "RepairDNA sets repair_mechanism + damage_site" do
    tests "RepairDNA", on: "DNA"
    setup  "SequenceDNA", sequence: "sample", organism: "sample", strand_type: "sample"
    input  repair_mechanism: "sample", damage_site: 1
    expect integrity: 1.0
  end

  test "Methylate sets gene_name + methylation_pattern" do
    tests "Methylate", on: "DNA"
    setup  "SequenceDNA", sequence: "sample", organism: "sample", strand_type: "sample"
    input  gene_name: "sample", methylation_pattern: "sample"
    expect ok: "true"
  end

  test "Splice sets gene_name + exons_retained" do
    tests "Splice", on: "DNA"
    setup  "SequenceDNA", sequence: "sample", organism: "sample", strand_type: "sample"
    input  gene_name: "sample", exons_retained: "sample"
    expect ok: "true"
  end


  # ── Protein aggregate ──────────────────────────────────────────

  test "Synthesize sets name + sequence" do
    tests "Synthesize", on: "Protein"
    input  name: "sample", sequence: "sample"
    expect name: "sample", sequence: "sample", function: "enzyme", active: "false", folding_state: "unfolded"
  end

  test "Fold sets secondary_structure + tertiary_structure" do
    tests "Fold", on: "Protein"
    setup  "Synthesize", name: "sample", sequence: "sample"
    input  secondary_structure: "sample", tertiary_structure: "sample"
    expect secondary_structure: "sample", tertiary_structure: "sample", active: "true", folding_state: "folded"
  end

  test "Denature sets cause" do
    tests "Denature", on: "Protein"
    setup  "Synthesize", name: "sample", sequence: "sample"
    setup  "Fold", secondary_structure: "sample", tertiary_structure: "sample"
    input  cause: "sample"
    expect active: "false", folding_state: "denatured"
  end

  test "Catalyze sets substrate + product" do
    tests "Catalyze", on: "Protein"
    setup  "Synthesize", name: "sample", sequence: "sample"
    setup  "Fold", secondary_structure: "sample", tertiary_structure: "sample"
    input  substrate: "sample", product: "sample"
    expect ok: "true"
  end

  test "Phosphorylate sets site + kinase" do
    tests "Phosphorylate", on: "Protein"
    setup  "Synthesize", name: "sample", sequence: "sample"
    input  site: "sample", kinase: "sample"
    expect ok: "true"
  end

  test "Bind sets target + binding_affinity" do
    tests "Bind", on: "Protein"
    setup  "Synthesize", name: "sample", sequence: "sample"
    input  target: "sample", binding_affinity: 1.0
    expect ok: "true"
  end


  # ── Organism aggregate ──────────────────────────────────────────

  test "Classify sets species_name + common_name + domain + kingdom + phylum" do
    tests "Classify", on: "Organism"
    input  species_name: "sample", common_name: "sample", domain: "sample", kingdom: "sample", phylum: "sample"
    expect species_name: "sample", common_name: "sample", domain: "sample", kingdom: "sample", phylum: "sample", alive: "true", generation: 1
  end

  test "Evolve sets trait_name + new_value + mechanism" do
    tests "Evolve", on: "Organism"
    setup  "Classify", species_name: "sample", common_name: "sample", domain: "sample", kingdom: "sample", phylum: "sample"
    input  trait_name: "sample", new_value: "sample", mechanism: "sample"
    expect ok: "true"
  end

  test "Adapt sets pressure + adaptation" do
    tests "Adapt", on: "Organism"
    setup  "Classify", species_name: "sample", common_name: "sample", domain: "sample", kingdom: "sample", phylum: "sample"
    input  pressure: "sample", adaptation: "sample"
    expect ok: "true"
  end

  test "Reproduce sets reproduction_type + mate_id" do
    tests "Reproduce", on: "Organism"
    setup  "Classify", species_name: "sample", common_name: "sample", domain: "sample", kingdom: "sample", phylum: "sample"
    input  reproduction_type: "sample", mate_id: "sample"
    expect ok: "true"
  end

  test "Kill sets cause" do
    tests "Kill", on: "Organism"
    setup  "Classify", species_name: "sample", common_name: "sample", domain: "sample", kingdom: "sample", phylum: "sample"
    input  cause: "sample"
    expect alive: "false"
  end


  # ── Ecosystem aggregate ──────────────────────────────────────────

  test "EstablishEcosystem sets name + biome + area + energy_input" do
    tests "EstablishEcosystem", on: "Ecosystem"
    input  name: "sample", biome: "sample", area: 1.0, energy_input: 1.0
    expect name: "sample", biome: "sample", area: 1.0, energy_input: 1.0, status: "nascent"
  end

  test "AddSpecies sets species_name + initial_count + trophic_level" do
    tests "AddSpecies", on: "Ecosystem"
    setup  "EstablishEcosystem", name: "sample", biome: "sample", area: 1.0, energy_input: 1.0
    input  species_name: "sample", initial_count: 1, trophic_level: "sample"
    expect status: "developing"
  end

  test "AddSpecies cascades through policy chain" do
    tests "AddSpecies", on: "Ecosystem", kind: :cascade
    setup  "EstablishEcosystem", name: "sample", biome: "sample", area: 1.0, energy_input: 1.0
    input  species_name: "sample", initial_count: 1, trophic_level: "sample"
    expect emits: ["SpeciesAdded", "FoodWebModeled"]
  end

  test "TrackPopulation sets species_name + new_count + growth_rate" do
    tests "TrackPopulation", on: "Ecosystem"
    setup  "EstablishEcosystem", name: "sample", biome: "sample", area: 1.0, energy_input: 1.0
    input  species_name: "sample", new_count: 1, growth_rate: 1.0
    expect ok: "true"
  end

  test "ModelFoodWeb runs" do
    tests "ModelFoodWeb", on: "Ecosystem"
    setup  "EstablishEcosystem", name: "sample", biome: "sample", area: 1.0, energy_input: 1.0
    setup  "AddSpecies", species_name: "sample", initial_count: 1, trophic_level: "sample"
    expect status: "stable"
  end

  test "MeasureBiodiversity sets biodiversity_index" do
    tests "MeasureBiodiversity", on: "Ecosystem"
    setup  "EstablishEcosystem", name: "sample", biome: "sample", area: 1.0, energy_input: 1.0
    input  biodiversity_index: 1.0
    expect biodiversity_index: 1.0
  end

  test "RemoveSpecies sets species_name + cause" do
    tests "RemoveSpecies", on: "Ecosystem"
    setup  "EstablishEcosystem", name: "sample", biome: "sample", area: 1.0, energy_input: 1.0
    setup  "AddSpecies", species_name: "sample", initial_count: 1, trophic_level: "sample"
    setup  "ModelFoodWeb"
    input  species_name: "sample", cause: "sample"
    expect status: "disturbed"
  end

  test "RemoveSpecies cascades through policy chain" do
    tests "RemoveSpecies", on: "Ecosystem", kind: :cascade
    setup  "EstablishEcosystem", name: "sample", biome: "sample", area: 1.0, energy_input: 1.0
    setup  "AddSpecies", species_name: "sample", initial_count: 1, trophic_level: "sample"
    setup  "ModelFoodWeb"
    input  species_name: "sample", cause: "sample"
    expect emits: ["SpeciesRemoved", "BiodiversityMeasured"]
  end


  # ── Genetics aggregate ──────────────────────────────────────────

  test "DefineGenotype sets organism_name + genotype + ploidy" do
    tests "DefineGenotype", on: "Genetics"
    input  organism_name: "sample", genotype: "sample", ploidy: "sample"
    expect organism_name: "sample", genotype: "sample", ploidy: "sample", genome_mapped: "false"
  end

  test "CrossBreed sets mate_genotype + cross_type" do
    tests "CrossBreed", on: "Genetics"
    setup  "DefineGenotype", organism_name: "sample", genotype: "sample", ploidy: "sample"
    input  mate_genotype: "sample", cross_type: "sample"
    expect ok: "true"
  end

  test "ExpressGene sets gene_name + phenotype" do
    tests "ExpressGene", on: "Genetics"
    setup  "DefineGenotype", organism_name: "sample", genotype: "sample", ploidy: "sample"
    input  gene_name: "sample", phenotype: "sample"
    expect phenotype: "sample"
  end

  test "MapGenome sets chromosome_count" do
    tests "MapGenome", on: "Genetics"
    setup  "DefineGenotype", organism_name: "sample", genotype: "sample", ploidy: "sample"
    input  chromosome_count: 1
    expect chromosome_count: 1, genome_mapped: "true"
  end

  test "IdentifyTrait sets trait_name + allele_combination" do
    tests "IdentifyTrait", on: "Genetics"
    setup  "DefineGenotype", organism_name: "sample", genotype: "sample", ploidy: "sample"
    input  trait_name: "sample", allele_combination: "sample"
