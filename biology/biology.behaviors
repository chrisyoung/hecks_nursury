  end

  test "DetectMutation sets gene_name + mutation_type + effect" do
    tests "DetectMutation", on: "Genetics"
    setup  "DefineGenotype", organism_name: "sample", genotype: "sample", ploidy: "sample"
    input  gene_name: "sample", mutation_type: "sample", effect: "sample"
    expect ok: "true"
  end


  # ── Evolution aggregate ──────────────────────────────────────────

  test "TrackLineage sets lineage_name + selection_pressure" do
    tests "TrackLineage", on: "Evolution"
    input  lineage_name: "sample", selection_pressure: "sample"
    expect lineage_name: "sample", selection_pressure: "sample", generation_count: 1, speciation_events: 0
  end

  test "SelectFittest sets trait_favored + survivors_fraction" do
    tests "SelectFittest", on: "Evolution"
    setup  "TrackLineage", lineage_name: "sample", selection_pressure: "sample"
    input  trait_favored: "sample", survivors_fraction: 1.0
    expect ok: "true"
  end

  test "SelectFittest cascades through policy chain" do
    tests "SelectFittest", on: "Evolution", kind: :cascade
    setup  "TrackLineage", lineage_name: "sample", selection_pressure: "sample"
    input  trait_favored: "sample", survivors_fraction: 1.0
    expect emits: ["FittestSelected", "AdaptationTracked"]
  end

  test "Speciate sets mechanism + new_species_name + barrier" do
    tests "Speciate", on: "Evolution"
    setup  "TrackLineage", lineage_name: "sample", selection_pressure: "sample"
    input  mechanism: "sample", new_species_name: "sample", barrier: "sample"
    expect ok: "true"
  end

  test "TrackAdaptation sets trait + pressure + fitness_delta" do
    tests "TrackAdaptation", on: "Evolution"
    setup  "TrackLineage", lineage_name: "sample", selection_pressure: "sample"
    input  trait: "sample", pressure: "sample", fitness_delta: 1.0
    expect ok: "true"
  end

  test "DateDivergence sets sister_lineage + divergence_time + method" do
    tests "DateDivergence", on: "Evolution"
    setup  "TrackLineage", lineage_name: "sample", selection_pressure: "sample"
    input  sister_lineage: "sample", divergence_time: 1.0, method: "sample"
    expect divergence_time: 1.0
  end

  test "MeasureDrift sets population_size + allele + frequency_change" do
    tests "MeasureDrift", on: "Evolution"
    setup  "TrackLineage", lineage_name: "sample", selection_pressure: "sample"
    input  population_size: 1, allele: "sample", frequency_change: 1.0
    expect ok: "true"
  end


  # ── Neuron aggregate ──────────────────────────────────────────

  test "DefineNeuron sets neuron_type + name + resting_potential + threshold + neurotransmitter" do
    tests "DefineNeuron", on: "Neuron"
    input  neuron_type: "sample", name: "sample", resting_potential: 1.0, threshold: 1.0, neurotransmitter: "sample"
    expect neuron_type: "sample", name: "sample", resting_potential: 1.0, threshold: 1.0, neurotransmitter: "sample", current_potential: 1.0, state: "resting"
  end

  test "FireNeuron sets stimulus_strength" do
    tests "FireNeuron", on: "Neuron"
    setup  "DefineNeuron", neuron_type: "sample", name: "sample", resting_potential: 1.0, threshold: 1.0, neurotransmitter: "sample"
    input  stimulus_strength: 1.0
    expect state: "firing"
  end

  test "FireNeuron cascades through policy chain" do
    tests "FireNeuron", on: "Neuron", kind: :cascade
    setup  "DefineNeuron", neuron_type: "sample", name: "sample", resting_potential: 1.0, threshold: 1.0, neurotransmitter: "sample"
    input  stimulus_strength: 1.0
    expect emits: ["NeuronFired", "SynapseReleased", "SignalPropagated", "NeuronRepolarized"]
  end

  test "Depolarize sets potential_change" do
    tests "Depolarize", on: "Neuron"
    setup  "DefineNeuron", neuron_type: "sample", name: "sample", resting_potential: 1.0, threshold: 1.0, neurotransmitter: "sample"
    setup  "FireNeuron", stimulus_strength: 1.0
    setup  "Repolarize"
    input  potential_change: 1.0
    expect state: "resting"
  end

  test "Repolarize runs" do
    tests "Repolarize", on: "Neuron"
    setup  "DefineNeuron", neuron_type: "sample", name: "sample", resting_potential: 1.0, threshold: 1.0, neurotransmitter: "sample"
    setup  "FireNeuron", stimulus_strength: 1.0
    expect state: "refractory"
  end

  test "ReleaseSynapse sets target_neuron + amount" do
    tests "ReleaseSynapse", on: "Neuron"
    setup  "DefineNeuron", neuron_type: "sample", name: "sample", resting_potential: 1.0, threshold: 1.0, neurotransmitter: "sample"
    setup  "FireNeuron", stimulus_strength: 1.0
    input  target_neuron: "sample", amount: 1.0
    expect ok: "true"
  end

  test "PropagateSignal sets conduction_type + velocity" do
    tests "PropagateSignal", on: "Neuron"
    setup  "DefineNeuron", neuron_type: "sample", name: "sample", resting_potential: 1.0, threshold: 1.0, neurotransmitter: "sample"
    setup  "FireNeuron", stimulus_strength: 1.0
    input  conduction_type: "sample", velocity: 1.0
    expect ok: "true"
  end

  test "PropagateSignal cascades through policy chain" do
    tests "PropagateSignal", on: "Neuron", kind: :cascade
    setup  "DefineNeuron", neuron_type: "sample", name: "sample", resting_potential: 1.0, threshold: 1.0, neurotransmitter: "sample"
    setup  "FireNeuron", stimulus_strength: 1.0
    input  conduction_type: "sample", velocity: 1.0
    expect emits: ["SignalPropagated", "NeuronRepolarized"]
  end

  test "FormMemory sets synapse_target + strength_increase" do
    tests "FormMemory", on: "Neuron"
    setup  "DefineNeuron", neuron_type: "sample", name: "sample", resting_potential: 1.0, threshold: 1.0, neurotransmitter: "sample"
    input  synapse_target: "sample", strength_increase: 1.0
    expect ok: "true"
  end

  test "Inhibit sets inhibitor" do
    tests "Inhibit", on: "Neuron"
    setup  "DefineNeuron", neuron_type: "sample", name: "sample", resting_potential: 1.0, threshold: 1.0, neurotransmitter: "sample"
    input  inhibitor: "sample"
    expect state: "inhibited"
  end


  # ── ImmuneResponse aggregate ──────────────────────────────────────────

  test "DetectPathogen sets pathogen_name + pathogen_type + severity" do
    tests "DetectPathogen", on: "ImmuneResponse"
    input  pathogen_name: "sample", pathogen_type: "sample", severity: "sample"
    expect pathogen_name: "sample", pathogen_type: "sample", severity: "sample", memory_formed: "false", status: "detected"
  end

  test "DetectPathogen cascades through policy chain" do
    tests "DetectPathogen", on: "ImmuneResponse", kind: :cascade
    input  pathogen_name: "sample", pathogen_type: "sample", severity: "sample"
    expect emits: ["PathogenDetected", "ResponseMounted", "AntibodyGenerated"]
  end

  test "MountResponse runs" do
    tests "MountResponse", on: "ImmuneResponse"
    setup  "DetectPathogen", pathogen_name: "sample", pathogen_type: "sample", severity: "sample"
    expect response_type: "adaptive", status: "active"
  end

  test "MountResponse cascades through policy chain" do
    tests "MountResponse", on: "ImmuneResponse", kind: :cascade
    setup  "DetectPathogen", pathogen_name: "sample", pathogen_type: "sample", severity: "sample"
    expect emits: ["ResponseMounted", "AntibodyGenerated"]
  end

  test "GenerateAntibody sets antibody_name + isotype" do
    tests "GenerateAntibody", on: "ImmuneResponse"
    setup  "DetectPathogen", pathogen_name: "sample", pathogen_type: "sample", severity: "sample"
    setup  "MountResponse"
    input  antibody_name: "sample", isotype: "sample"
    expect antibody_generated: "sample"
  end

  test "RememberPathogen runs" do
    tests "RememberPathogen", on: "ImmuneResponse"
    setup  "DetectPathogen", pathogen_name: "sample", pathogen_type: "sample", severity: "sample"
    setup  "MountResponse"
    setup  "ResolveInfection"
    expect memory_formed: "true", status: "immune"
  end

  test "Engulf sets cell_type + target" do
    tests "Engulf", on: "ImmuneResponse"
    setup  "DetectPathogen", pathogen_name: "sample", pathogen_type: "sample", severity: "sample"
    input  cell_type: "sample", target: "sample"
    expect ok: "true"
  end

  test "ResolveInfection runs" do
    tests "ResolveInfection", on: "ImmuneResponse"
    setup  "DetectPathogen", pathogen_name: "sample", pathogen_type: "sample", severity: "sample"
    setup  "MountResponse"
    expect status: "resolved"
  end

  test "ResolveInfection cascades through policy chain" do
    tests "ResolveInfection", on: "ImmuneResponse", kind: :cascade
    setup  "DetectPathogen", pathogen_name: "sample", pathogen_type: "sample", severity: "sample"
    setup  "MountResponse"
    expect emits: ["InfectionResolved", "PathogenRemembered"]
  end


