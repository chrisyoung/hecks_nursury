Hecks.behaviors "Tribology" do
  vision "Behavioral tests for the Tribology domain — exercises every command and query in memory"

  # ── Surface aggregate ──────────────────────────────────────────

  test "CharacterizeSurface sets name + material + hardness + elastic_modulus + surface_energy" do
    tests "CharacterizeSurface", on: "Surface"
    input  name: "sample", material: "sample", hardness: 1.0, elastic_modulus: 1.0, surface_energy: 1.0
    expect name: "sample", material: "sample", hardness: 1.0, elastic_modulus: 1.0, surface_energy: 1.0
  end

  test "MeasureRoughness sets ra + rz + rq" do
    tests "MeasureRoughness", on: "Surface"
    setup  "CharacterizeSurface", name: "sample", material: "sample", hardness: 1.0, elastic_modulus: 1.0, surface_energy: 1.0
    input  ra: 1.0, rz: 1.0, rq: 1.0
    expect ok: "true"
  end

  test "MapTopography sets scan_area_mm2 + resolution_um" do
    tests "MapTopography", on: "Surface"
    setup  "CharacterizeSurface", name: "sample", material: "sample", hardness: 1.0, elastic_modulus: 1.0, surface_energy: 1.0
    input  scan_area_mm2: 1.0, resolution_um: 1.0
    expect ok: "true"
  end

  test "AnalyzeMicrostructure sets method + grain_size_um" do
    tests "AnalyzeMicrostructure", on: "Surface"
    setup  "CharacterizeSurface", name: "sample", material: "sample", hardness: 1.0, elastic_modulus: 1.0, surface_energy: 1.0
    input  method: "sample", grain_size_um: 1.0
    expect ok: "true"
  end


  # ── Friction aggregate ──────────────────────────────────────────

  test "MeasureFriction sets name + surface_a + surface_b + normal_load + sliding_speed" do
    tests "MeasureFriction", on: "Friction"
    input  name: "sample", surface_a: "sample", surface_b: "sample", normal_load: 1.0, sliding_speed: 1.0
    expect name: "sample", surface_a: "sample", surface_b: "sample", normal_load: 1.0, sliding_speed: 1.0, status: "measured"
  end

  test "MeasureFriction cascades through policy chain" do
    tests "MeasureFriction", on: "Friction", kind: :cascade
    setup  "CalculateFlashTemperature", name: "sample", friction_coefficient: 1.0, load: 1.0, sliding_speed: 1.0, thermal_conductivity: 1.0
    input  name: "sample", surface_a: "sample", surface_b: "sample", normal_load: 1.0, sliding_speed: 1.0
    expect emits: ["FrictionMeasured", "FlashTemperatureCalculated", "ThermalBreakdownPredicted", "CoefficientCalculated"]
  end

  test "CalculateCoefficient sets friction_force + normal_force" do
    tests "CalculateCoefficient", on: "Friction"
    setup  "MeasureFriction", name: "sample", surface_a: "sample", surface_b: "sample", normal_load: 1.0, sliding_speed: 1.0
    input  friction_force: 1.0, normal_force: 1.0
    expect ok: "true"
  end

  test "ClassifyFrictionRegime sets regime" do
    tests "ClassifyFrictionRegime", on: "Friction"
    setup  "MeasureFriction", name: "sample", surface_a: "sample", surface_b: "sample", normal_load: 1.0, sliding_speed: 1.0
    input  regime: "sample"
    expect regime: "sample"
  end

  test "MapStribeckCurve sets speed_range_min + speed_range_max + viscosity" do
    tests "MapStribeckCurve", on: "Friction"
    setup  "MeasureFriction", name: "sample", surface_a: "sample", surface_b: "sample", normal_load: 1.0, sliding_speed: 1.0
    input  speed_range_min: 1.0, speed_range_max: 1.0, viscosity: 1.0
    expect ok: "true"
  end

  test "ReduceFriction sets method + target_cof" do
    tests "ReduceFriction", on: "Friction"
    setup  "MeasureFriction", name: "sample", surface_a: "sample", surface_b: "sample", normal_load: 1.0, sliding_speed: 1.0
    input  method: "sample", target_cof: 1.0
    expect ok: "true"
  end


  # ── Wear aggregate ──────────────────────────────────────────

  test "MeasureWear sets name + test_method" do
    tests "MeasureWear", on: "Wear"
    input  name: "sample", test_method: "sample"
    expect name: "sample", test_method: "sample", status: "measured"
  end

  test "MeasureWear cascades through policy chain" do
    tests "MeasureWear", on: "Wear", kind: :cascade
    input  name: "sample", test_method: "sample"
    expect emits: ["WearMeasured", "WearDebrisAnalyzed"]
  end

  test "ClassifyWearMechanism sets mechanism" do
    tests "ClassifyWearMechanism", on: "Wear"
    setup  "MeasureWear", name: "sample", test_method: "sample"
    input  mechanism: "sample"
    expect mechanism: "sample", status: "classified"
  end

  test "PredictWearRate sets load + sliding_distance + hardness + wear_coefficient" do
    tests "PredictWearRate", on: "Wear"
    setup  "MeasureWear", name: "sample", test_method: "sample"
    input  load: 1.0, sliding_distance: 1.0, hardness: 1.0, wear_coefficient: 1.0
    expect ok: "true"
  end

  test "AnalyzeWearDebris sets particle_size_um + morphology + composition" do
    tests "AnalyzeWearDebris", on: "Wear"
    setup  "MeasureWear", name: "sample", test_method: "sample"
    input  particle_size_um: 1.0, morphology: "sample", composition: "sample"
    expect ok: "true"
  end


  # ── Lubricant aggregate ──────────────────────────────────────────

  test "FormulateLubricant sets name + base_oil_type + sae_grade" do
    tests "FormulateLubricant", on: "Lubricant"
    input  name: "sample", base_oil_type: "sample", sae_grade: "sample"
    expect name: "sample", base_oil_type: "sample", sae_grade: "sample", status: "formulated"
  end

  test "FormulateLubricant cascades through policy chain" do
    tests "FormulateLubricant", on: "Lubricant", kind: :cascade
    setup  "MeasureFilmThickness", name: "sample", method: "sample", thickness_nm: 1.0
    setup  "RunTest", name: "sample", test_standard: "sample", apparatus: "sample"
    input  name: "sample", base_oil_type: "sample", sae_grade: "sample"
    expect emits: ["LubricantFormulated", "MinimumFilmCalculated", "TestRun"]
  end

  test "MeasureViscosity sets kinematic_40c + kinematic_100c" do
    tests "MeasureViscosity", on: "Lubricant"
    setup  "FormulateLubricant", name: "sample", base_oil_type: "sample", sae_grade: "sample"
    input  kinematic_40c: 1.0, kinematic_100c: 1.0
    expect ok: "true"
  end

  test "MeasureViscosity cascades through policy chain" do
    tests "MeasureViscosity", on: "Lubricant", kind: :cascade
    setup  "FormulateLubricant", name: "sample", base_oil_type: "sample", sae_grade: "sample"
    setup  "IdentifyRegime", name: "sample", lambda_ratio: 1.0
    setup  "MeasureWear", name: "sample", test_method: "sample"
    input  kinematic_40c: 1.0, kinematic_100c: 1.0
    expect emits: ["ViscosityMeasured", "RegimeIdentified", "WearRatePredicted"]
  end

  test "CalculateViscosityIndex sets kinematic_40c + kinematic_100c" do
    tests "CalculateViscosityIndex", on: "Lubricant"
    setup  "FormulateLubricant", name: "sample", base_oil_type: "sample", sae_grade: "sample"
    input  kinematic_40c: 1.0, kinematic_100c: 1.0
    expect ok: "true"
  end

  test "TestPourPoint sets pour_point_c" do
    tests "TestPourPoint", on: "Lubricant"
    setup  "FormulateLubricant", name: "sample", base_oil_type: "sample", sae_grade: "sample"
    input  pour_point_c: 1.0
    expect pour_point_c: 1.0, status: "tested"
  end

  test "TestFlashPoint sets flash_point_c" do
    tests "TestFlashPoint", on: "Lubricant"
    setup  "FormulateLubricant", name: "sample", base_oil_type: "sample", sae_grade: "sample"
    input  flash_point_c: 1.0
    expect flash_point_c: 1.0, status: "tested"
  end

  test "AnalyzeFilmThickness sets film_thickness_nm + temperature_c + load_n" do
    tests "AnalyzeFilmThickness", on: "Lubricant"
    setup  "FormulateLubricant", name: "sample", base_oil_type: "sample", sae_grade: "sample"
    input  film_thickness_nm: 1.0, temperature_c: 1.0, load_n: 1.0
    expect ok: "true"
  end


  # ── LubricationRegime aggregate ──────────────────────────────────────────

  test "IdentifyRegime sets name + lambda_ratio" do
    tests "IdentifyRegime", on: "LubricationRegime"
    input  name: "sample", lambda_ratio: 1.0
    expect name: "sample", lambda_ratio: 1.0, regime_type: "pending", status: "identified"
  end

  test "IdentifyRegime cascades through policy chain" do
    tests "IdentifyRegime", on: "LubricationRegime", kind: :cascade
    setup  "MeasureWear", name: "sample", test_method: "sample"
    input  name: "sample", lambda_ratio: 1.0
    expect emits: ["RegimeIdentified", "WearRatePredicted"]
  end

  test "CalculateFilmParameter sets min_film_thickness + composite_roughness" do
    tests "CalculateFilmParameter", on: "LubricationRegime"
    setup  "IdentifyRegime", name: "sample", lambda_ratio: 1.0
    input  min_film_thickness: 1.0, composite_roughness: 1.0
    expect ok: "true"
  end

  test "TransitionRegime sets from_regime + to_regime + cause" do
    tests "TransitionRegime", on: "LubricationRegime"
    setup  "IdentifyRegime", name: "sample", lambda_ratio: 1.0
    input  from_regime: "sample", to_regime: "sample", cause: "sample"
    expect regime_type: "sample", status: "transitioned"
  end

  test "TransitionRegime cascades through policy chain" do
    tests "TransitionRegime", on: "LubricationRegime", kind: :cascade
    setup  "MeasureFilmThickness", name: "sample", method: "sample", thickness_nm: 1.0
    setup  "IdentifyRegime", name: "sample", lambda_ratio: 1.0
    input  from_regime: "sample", to_regime: "sample", cause: "sample"
    expect emits: ["RegimeTransitioned", "FilmThicknessMeasured"]
  end

  test "OptimizeRegime sets target_regime + method" do
    tests "OptimizeRegime", on: "LubricationRegime"
    setup  "IdentifyRegime", name: "sample", lambda_ratio: 1.0
    input  target_regime: "sample", method: "sample"
    expect status: "optimized"
  end


