  test "AnalyzeStressField sets max_pressure + poisson_ratio" do
    tests "AnalyzeStressField", on: "ContactMechanics"
    setup  "CalculateContactPressure", name: "sample", contact_type: "sample", load: 1.0, radius_a: 1.0, radius_b: 1.0, modulus_a: 1.0, modulus_b: 1.0
