Hecks.bluebook "DevOpsPipeline", version: "2026.04.13.1" do
  vision "Automating software delivery — managing repos, building artifacts, deploying releases, rolling back failures, and tracking pipeline metrics"
  category "technology"

  aggregate "Repository", "A source code repository tracked by the pipeline" do
    attribute :repo_name, String
    attribute :clone_url, String
    attribute :default_branch, String
    attribute :language, String
    attribute :status, String
    attribute :webhooks, list_of(Webhook)

    value_object "Webhook" do
      attribute :event_type, String
      attribute :callback_url, String
      attribute :secret, String
    end

    command "RegisterRepository" do
      role "PlatformEngineer"
      description "Connect a source code repository to the pipeline"
      attribute :repo_name, String
      attribute :clone_url, String
      attribute :default_branch, String
      attribute :language, String
      then_set :status, to: "idle"
      emits "RepositoryRegistered"
    end

    command "RetargetBranch" do
      description "Change the default branch tracked for builds"
      reference_to(Repository)
      attribute :default_branch, String
      emits "BranchRetargeted"
    end

    command "DisconnectRepository" do
      description "Remove a repository from the pipeline"
      reference_to(Repository)
      given("no active builds") { status == "idle" }
      emits "RepositoryDisconnected"
    end
  end

  aggregate "Build", "A compilation and test run producing a deployable artifact" do
    attribute :build_number, String
    attribute :commit_sha, String
    attribute :artifact_url, String
    attribute :duration_seconds, Integer
    attribute :status, String
    reference_to Repository
    attribute :steps, list_of(BuildStep)

    value_object "BuildStep" do
      attribute :step_name, String
      attribute :outcome, String
      attribute :duration_seconds, Integer
    end

    command "TriggerBuild" do
      role "CI System"
      description "Start a new build from a commit"
      attribute :build_number, String
      attribute :commit_sha, String
      reference_to(Repository)
      emits "BuildTriggered"
    end

    command "CompleteBuild" do
      description "Mark a build as finished with an artifact URL"
      reference_to(Build)
      attribute :artifact_url, String
      attribute :duration_seconds, Integer
      emits "BuildCompleted"
    end

    command "FailBuild" do
      description "Record a build failure with error details"
      reference_to(Build)
      attribute :error_message, String
      emits "BuildFailed"
    end
  end

  aggregate "Deployment", "A release of a build artifact to a target environment" do
    attribute :deploy_id, String
    attribute :environment, String
    attribute :strategy, String
    attribute :deployed_by, String
    attribute :status, String
    reference_to Build
    attribute :health_checks, list_of(HealthCheck)

    value_object "HealthCheck" do
      attribute :endpoint, String
      attribute :response_code, Integer
      attribute :checked_at, String
    end

    command "DeployArtifact" do
      role "ReleaseEngineer"
      description "Push a build artifact to a target environment"
      attribute :deploy_id, String
      attribute :environment, String
      attribute :strategy, String
      attribute :deployed_by, String
      reference_to(Build)
      then_set :status, to: "healthy"
      emits "ArtifactDeployed"
    end

    command "PromoteDeployment" do
      description "Advance a deployment from staging to production"
      reference_to(Deployment)
      given("deployment is healthy") { status == "healthy" }
      emits "DeploymentPromoted"
    end

    command "AbortDeployment" do
      description "Stop an in-progress deployment due to issues"
      reference_to(Deployment)
      emits "DeploymentAborted"
    end
  end

  aggregate "Rollback", "A reversion to a previous deployment after a failure" do
    attribute :rollback_id, String
    attribute :reason, String
    attribute :target_version, String
    attribute :initiated_by, String
    attribute :status, String
    reference_to Deployment

    value_object "RollbackStep" do
      attribute :action, String
      attribute :outcome, String
      attribute :completed_at, String
    end

    command "InitiateRollback" do
      role "OnCallEngineer"
      description "Begin reverting to a prior known-good deployment"
      attribute :rollback_id, String
      attribute :reason, String
      attribute :target_version, String
      attribute :initiated_by, String
      reference_to(Deployment)
      then_set :status, to: "in_progress"
      emits "RollbackInitiated"
    end

    command "CompleteRollback" do
      description "Confirm the rollback restored service successfully"
      reference_to(Rollback)
      given("rollback is in progress") { status == "in_progress" }
      emits "RollbackCompleted"
    end

    command "AbandonRollback" do
      description "Cancel a rollback that is no longer needed"
      reference_to(Rollback)
      emits "RollbackAbandoned"
    end
  end

  aggregate "PipelineMetric", "A performance measurement for pipeline health" do
    attribute :metric_name, String
    attribute :value, Float
    attribute :unit, String
    attribute :period, String
    attribute :status, String
    reference_to Repository

    value_object "Threshold" do
      attribute :warning_level, Float
      attribute :critical_level, Float
      attribute :direction, String
    end

    command "RecordMetric" do
      role "MetricsCollector"
      description "Log a pipeline performance metric for a period"
      attribute :metric_name, String
      attribute :value, Float
      attribute :unit, String
      attribute :period, String
      reference_to(Repository)
      emits "MetricRecorded"
    end

    command "SetThreshold" do
      description "Define warning and critical levels for a metric"
      reference_to(PipelineMetric)
      attribute :warning_level, Float
      attribute :critical_level, Float
      emits "ThresholdSet"
    end

    command "AlertOnBreach" do
      description "Fire an alert when a metric exceeds its threshold"
      reference_to(PipelineMetric)
      given("metric exceeds threshold") { value > 0 }
      emits "ThresholdBreached"
    end
  end

  lifecycle "ReleaseFlow" do
    state "code_pushed"
    state "building"
    state "tested"
    state "staged"
    state "canary"
    state "production"
    state "rolled_back"

    transition from: "code_pushed", to: "building", on: "BuildTriggered"
    transition from: "building", to: "tested", on: "BuildCompleted"
    transition from: "tested", to: "staged", on: "ArtifactDeployed"
    transition from: "staged", to: "canary", on: "DeploymentPromoted"
    transition from: "canary", to: "production", on: "DeploymentPromoted"
    transition from: "production", to: "rolled_back", on: "RollbackCompleted"
    transition from: "staged", to: "rolled_back", on: "DeploymentAborted"
  end

  policy "RepositoryRegisteredTriggerBuild" do
    on "RepositoryRegistered"
    trigger "TriggerBuild"
  end

  policy "BuildCompletedDeployToStaging" do
    on "BuildCompleted"
    trigger "DeployArtifact"
  end

  policy "ArtifactDeployedPromote" do
    on "ArtifactDeployed"
    trigger "PromoteDeployment"
  end

  policy "DeploymentPromotedRecordMetric" do
    on "DeploymentPromoted"
    trigger "RecordMetric"
  end

  policy "DeploymentAbortedRollback" do
    on "DeploymentAborted"
    trigger "InitiateRollback"
  end

  policy "ThresholdBreachedAlertOnBreach" do
    on "MetricRecorded"
    trigger "AlertOnBreach"
  end

  policy "BuildFailedTriggerRebuild" do
    on "BuildFailed"
    trigger "TriggerBuild"
  end

  policy "RollbackCompletedRecordMetric" do
    on "RollbackCompleted"
    trigger "RecordMetric"
  end

end
