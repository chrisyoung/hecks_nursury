  end
  aggregate "Revision" do
    fixture "Revision1", revision_number: 1, reviewer_name: "Sarah Mitchell", comments: "Clarify egress widths on north stair", status: "approved"
    fixture "Revision2", revision_number: 2, reviewer_name: "Building Official Chen", comments: "Add fire rating details", status: "pending"
  end
  aggregate "Permit" do
