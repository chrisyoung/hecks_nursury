    fixture "Permit2", permit_type: "Zoning Variance", jurisdiction: "County Planning Board", status: "submitted", permit_number: ""
  end
  aggregate "SiteVisit" do
    fixture "SiteVisit1", date: "2026-04-12", inspector_name: "James Thompson", weather_conditions: "Clear, 65F", status: "completed"
    fixture "SiteVisit2", date: "2026-04-20", inspector_name: "Patricia Lee", weather_conditions: "Overcast", status: "scheduled"
  end
