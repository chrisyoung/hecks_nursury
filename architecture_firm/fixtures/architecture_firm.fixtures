Hecks.fixtures "ArchitectureFirm" do
  aggregate "ArchProject" do
    fixture "Downtown_Mixed_Use_Development_", name: "Downtown Mixed-Use Development", building_type: "Mixed-Use", square_footage: 185000.0, budget: 42500000.0, phase: "schematic_design"
    fixture "Community_Health_Center_", name: "Community Health Center", building_type: "Medical", square_footage: 65000.0, budget: 18750000.0, phase: "design_development"
  end
  aggregate "Drawing" do
    fixture "Ground_Floor_Plan_Sheet_A1_01_", title: "Ground Floor Plan Sheet A1.01", drawing_type: "Floor Plan", scale: "1/8\"=1'", revision_number: 3, status: "under_review"
