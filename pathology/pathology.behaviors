  test "FailQualityControl cascades through policy chain" do
    tests "FailQualityControl", on: "QualityControl", kind: :cascade
    setup  "RunQualityControl", instrument_name: "sample", control_material: "sample", expected_value: "sample", observed_value: "sample", run_date: "sample"
    setup  "OrderTest", test_name: "sample", test_code: "sample", methodology: "sample", specimen_accession: "sample", ordered_by: "sample"
    expect emits: ["QualityControlFailed", "TestRepeated"]
  end


  # ── PathologyReport aggregate ──────────────────────────────────────────

  test "DraftPathologyReport sets patient_name + specimen_accession + gross_description + microscopic_findings + diagnosis + pathologist_name + report_date" do
    tests "DraftPathologyReport", on: "PathologyReport"
    setup  "ReceiveSpecimen", accession_number: "sample", patient_name: "sample", specimen_type: "sample", collection_date: "sample", collected_by: "sample"
    input  patient_name: "sample", specimen_accession: "sample", gross_description: "sample", microscopic_findings: "sample", diagnosis: "sample", pathologist_name: "sample", report_date: "sample"
