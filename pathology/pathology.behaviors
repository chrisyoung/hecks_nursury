Hecks.behaviors "Pathology" do
  vision "Behavioral tests for the Pathology domain — exercises every command and query in memory"

  # ── Specimen aggregate ──────────────────────────────────────────

  test "ReceiveSpecimen sets accession_number + patient_name + specimen_type + collection_date + collected_by" do
    tests "ReceiveSpecimen", on: "Specimen"
    input  accession_number: "sample", patient_name: "sample", specimen_type: "sample", collection_date: "sample", collected_by: "sample"
    expect accession_number: "sample", patient_name: "sample", specimen_type: "sample", collection_date: "sample", collected_by: "sample", status: "received"
  end

  test "ReceiveSpecimen cascades through policy chain" do
    tests "ReceiveSpecimen", on: "Specimen", kind: :cascade
    setup  "OrderTest", test_name: "sample", test_code: "sample", methodology: "sample", specimen_accession: "sample", ordered_by: "sample"
    setup  "RunQualityControl", instrument_name: "sample", control_material: "sample", expected_value: "sample", observed_value: "sample", run_date: "sample"
    input  accession_number: "sample", patient_name: "sample", specimen_type: "sample", collection_date: "sample", collected_by: "sample"
    expect emits: ["SpecimenAccessioned", "SpecimenProcessed", "TestOrdered", "QualityControlRun"]
  end

  test "ProcessSpecimen runs" do
    tests "ProcessSpecimen", on: "Specimen"
    setup  "ReceiveSpecimen", accession_number: "sample", patient_name: "sample", specimen_type: "sample", collection_date: "sample", collected_by: "sample"
    expect status: "processed"
  end

  test "ProcessSpecimen cascades through policy chain" do
    tests "ProcessSpecimen", on: "Specimen", kind: :cascade
    setup  "OrderTest", test_name: "sample", test_code: "sample", methodology: "sample", specimen_accession: "sample", ordered_by: "sample"
    setup  "RunQualityControl", instrument_name: "sample", control_material: "sample", expected_value: "sample", observed_value: "sample", run_date: "sample"
    setup  "ReceiveSpecimen", accession_number: "sample", patient_name: "sample", specimen_type: "sample", collection_date: "sample", collected_by: "sample"
    expect emits: ["SpecimenProcessed", "TestOrdered", "QualityControlRun"]
  end

  test "RejectSpecimen runs" do
    tests "RejectSpecimen", on: "Specimen"
    setup  "ReceiveSpecimen", accession_number: "sample", patient_name: "sample", specimen_type: "sample", collection_date: "sample", collected_by: "sample"
    expect status: "rejected"
  end


  # ── LabTest aggregate ──────────────────────────────────────────

  test "OrderTest sets test_name + test_code + methodology + specimen_accession + ordered_by" do
    tests "OrderTest", on: "LabTest"
    setup  "ReceiveSpecimen", accession_number: "sample", patient_name: "sample", specimen_type: "sample", collection_date: "sample", collected_by: "sample"
    input  test_name: "sample", test_code: "sample", methodology: "sample", specimen_accession: "sample", ordered_by: "sample"
    expect test_name: "sample", test_code: "sample", methodology: "sample", specimen_accession: "sample", ordered_by: "sample", status: "ordered"
  end

  test "OrderTest cascades through policy chain" do
    tests "OrderTest", on: "LabTest", kind: :cascade
    setup  "ReceiveSpecimen", accession_number: "sample", patient_name: "sample", specimen_type: "sample", collection_date: "sample", collected_by: "sample"
    setup  "RunQualityControl", instrument_name: "sample", control_material: "sample", expected_value: "sample", observed_value: "sample", run_date: "sample"
    input  test_name: "sample", test_code: "sample", methodology: "sample", specimen_accession: "sample", ordered_by: "sample"
    expect emits: ["TestOrdered", "QualityControlRun"]
  end

  test "RunTest runs" do
    tests "RunTest", on: "LabTest"
    setup  "OrderTest", test_name: "sample", test_code: "sample", methodology: "sample", specimen_accession: "sample", ordered_by: "sample"
    expect status: "completed"
  end

  test "RunTest cascades through policy chain" do
    tests "RunTest", on: "LabTest", kind: :cascade
    setup  "RecordResult", test_name: "sample", result_value: "sample", unit: "sample", reference_range: "sample", interpretation: "sample", resulted_by: "sample", result_date: "sample"
    setup  "DraftPathologyReport", patient_name: "sample", specimen_accession: "sample", gross_description: "sample", microscopic_findings: "sample", diagnosis: "sample", pathologist_name: "sample", report_date: "sample"
    setup  "ReceiveSpecimen", accession_number: "sample", patient_name: "sample", specimen_type: "sample", collection_date: "sample", collected_by: "sample"
    setup  "OrderTest", test_name: "sample", test_code: "sample", methodology: "sample", specimen_accession: "sample", ordered_by: "sample"
    expect emits: ["TestRun", "ResultRecorded", "ResultVerified", "PathologyReportDrafted", "PathologyReportSignedOut"]
  end

  test "RepeatTest runs" do
    tests "RepeatTest", on: "LabTest"
    setup  "OrderTest", test_name: "sample", test_code: "sample", methodology: "sample", specimen_accession: "sample", ordered_by: "sample"
    expect status: "ordered"
  end


