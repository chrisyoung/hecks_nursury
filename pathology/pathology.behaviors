    expect emits: ["ResultVerified", "PathologyReportDrafted", "PathologyReportSignedOut"]
  end

  test "AmendResult sets result_value + interpretation" do
    tests "AmendResult", on: "TestResult"
    setup  "RecordResult", test_name: "sample", result_value: "sample", unit: "sample", reference_range: "sample", interpretation: "sample", resulted_by: "sample", result_date: "sample"
    input  result_value: "sample", interpretation: "sample"
    expect result_value: "sample", interpretation: "sample"
  end


  # ── QualityControl aggregate ──────────────────────────────────────────

  test "RunQualityControl sets instrument_name + control_material + expected_value + observed_value + run_date" do
    tests "RunQualityControl", on: "QualityControl"
    input  instrument_name: "sample", control_material: "sample", expected_value: "sample", observed_value: "sample", run_date: "sample"
    expect instrument_name: "sample", control_material: "sample", expected_value: "sample", observed_value: "sample", run_date: "sample", status: "pending_review"
  end

  test "ApproveQualityControl runs" do
    tests "ApproveQualityControl", on: "QualityControl"
    setup  "RunQualityControl", instrument_name: "sample", control_material: "sample", expected_value: "sample", observed_value: "sample", run_date: "sample"
    expect status: "approved"
  end

  test "ApproveQualityControl cascades through policy chain" do
    tests "ApproveQualityControl", on: "QualityControl", kind: :cascade
    setup  "OrderTest", test_name: "sample", test_code: "sample", methodology: "sample", specimen_accession: "sample", ordered_by: "sample"
    setup  "RecordResult", test_name: "sample", result_value: "sample", unit: "sample", reference_range: "sample", interpretation: "sample", resulted_by: "sample", result_date: "sample"
    setup  "DraftPathologyReport", patient_name: "sample", specimen_accession: "sample", gross_description: "sample", microscopic_findings: "sample", diagnosis: "sample", pathologist_name: "sample", report_date: "sample"
    setup  "ReceiveSpecimen", accession_number: "sample", patient_name: "sample", specimen_type: "sample", collection_date: "sample", collected_by: "sample"
    setup  "RunQualityControl", instrument_name: "sample", control_material: "sample", expected_value: "sample", observed_value: "sample", run_date: "sample"
    expect emits: ["QualityControlApproved", "TestRun", "ResultRecorded", "ResultVerified", "PathologyReportDrafted", "PathologyReportSignedOut"]
  end

  test "FailQualityControl runs" do
    tests "FailQualityControl", on: "QualityControl"
    setup  "RunQualityControl", instrument_name: "sample", control_material: "sample", expected_value: "sample", observed_value: "sample", run_date: "sample"
    expect status: "failed"
