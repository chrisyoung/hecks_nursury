    fixture "Road_Tire_700x28c_", part_number: "WHE-700", name: "Road Tire 700x28c", category: "wheels", price: 45.00, quantity: 12
    fixture "Chain_10_speed_", part_number: "CHA-100", name: "Chain 10-speed", category: "drivetrain", price: 22.50, quantity: 8
    fixture "Drop_Bar_Handlebar_", part_number: "BAR-050", name: "Drop Bar Handlebar", category: "components", price: 35.00, quantity: 5
  end
  aggregate "BikeFitting" do
