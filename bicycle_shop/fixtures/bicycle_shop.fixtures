    fixture "Rental2", rental_id: "RNT-002", bike_id: "BK-2004", renter_name: "Rebecca Foster", start_date: "2026-04-13", end_date: "2026-04-15", daily_rate: 25.0, status: "returned"
    fixture "Rental3", rental_id: "RNT-003", bike_id: "BK-2001", renter_name: "Daniel Lee", start_date: "2026-04-15", end_date: "2026-04-17", daily_rate: 35.0, status: "rented"
