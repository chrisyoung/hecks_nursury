Hecks.fixtures "BicycleShop" do
  aggregate "Bicycle" do
    fixture "Bicycle1", bike_id: "BK-2001", brand: "Trek", model: "Domane AL 3", type: "road", frame_size: "56cm", price: 649.99, status: "available"
    fixture "Bicycle2", bike_id: "BK-2002", brand: "Specialized", model: "Rockhopper Sport 26", type: "mountain", frame_size: "medium", price: 399.99, status: "available"
    fixture "Bicycle3", bike_id: "BK-2003", brand: "Giant", model: "Escape 3", type: "hybrid", frame_size: "large", price: 299.99, status: "sold"
    fixture "Bicycle4", bike_id: "BK-2004", brand: "Cannondale", model: "Quick 5", type: "hybrid", frame_size: "medium", price: 449.99, status: "available"
  end
  aggregate "RepairOrder" do
