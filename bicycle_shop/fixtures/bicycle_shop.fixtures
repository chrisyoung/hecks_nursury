    fixture "BikeFitting2", fitting_id: "FIT-002", customer_name: "James Wilson", ride_style: "competitive_road", recommended_size: "large"
    fixture "BikeFitting3", fitting_id: "FIT-003", customer_name: "Sofia Reyes", ride_style: "mountain_trails", recommended_size: "medium"
