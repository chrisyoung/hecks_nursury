  aggregate "Watershed" do
    fixture "Bear_Creek_Basin_", name: "Bear Creek Basin", area_sq_km: 245.5, soil_type: "Clay Loam", impervious_pct: 18.5, runoff_coefficient: 0.42, status: "delineated"
    fixture "South_Platte_Tributary_", name: "South Platte Tributary", area_sq_km: 412.0, soil_type: "Sandy Loam", impervious_pct: 25.0, runoff_coefficient: 0.55, status: "delineated"
  end
  aggregate "DrainNetwork" do
    fixture "Downtown_Storm_Sewer_", name: "Downtown Storm Sewer", watershed_name: "Bear Creek Basin", total_capacity_cms: 45.5, inlet_count: 12, outlet_count: 2, status: "mapped"
    fixture "Industrial_Park_System_", name: "Industrial Park System", watershed_name: "South Platte Tributary", total_capacity_cms: 62.0, inlet_count: 18, outlet_count: 3, status: "mapped"
  end
  aggregate "StormEvent" do
