    fixture "Spring_Runoff_Peak_", name: "Spring Runoff Peak", intensity_mm_hr: 22.0, duration_hours: 4.0, return_period_years: 5, total_rainfall_mm: 88.0, runoff_volume_m3: 35200.0, status: "recorded"
  end
  aggregate "ComplianceReport" do
    fixture "ComplianceReport1", watershed_name: "Bear Creek Basin", permit_number: "PERMIT-2024-1847", max_discharge_cms: 42.0, actual_discharge_cms: 38.5, compliance_status: "Compliant", report_date: "2026-04-01", status: "filed"
    fixture "ComplianceReport2", watershed_name: "South Platte Tributary", permit_number: "PERMIT-2024-1848", max_discharge_cms: 60.0, actual_discharge_cms: 58.2, compliance_status: "Compliant", report_date: "2026-04-05", status: "filed"
  end
