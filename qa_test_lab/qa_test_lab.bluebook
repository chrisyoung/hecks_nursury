Hecks.bluebook "QATestLab", version: "2026.04.13.1" do
  vision "Running a QA lab — organizing projects, executing test suites, tracking bugs, managing environments, and gating releases"
  category "technology"

  aggregate "TestProject", "A software product under quality assurance" do
    attribute :project_name, String
    attribute :repository_url, String
    attribute :team_lead, String
    attribute :priority, String
    attribute :status, String
    attribute :milestones, list_of(Milestone)

    value_object "Milestone" do
      attribute :name, String
      attribute :target_date, String
      attribute :status, String
    end

    command "RegisterTestProject" do
      role "QAManager"
      description "Register a new software project for testing"
      attribute :project_name, String
      attribute :repository_url, String
      attribute :team_lead, String
      attribute :priority, String
      emits "TestProjectRegistered"
      then_set :status, to: "active"
    end

    command "AssignTeamLead" do
      description "Change the team lead responsible for a project"
      reference_to(TestProject)
      attribute :team_lead, String
      emits "TeamLeadAssigned"
    end

    command "CloseProject" do
      description "Archive a completed project"
      reference_to(TestProject)
      given("project milestones complete") { status == "active" }
      emits "ProjectClosed"
    end
  end

  aggregate "TestSuite", "A collection of test cases targeting a feature area" do
    attribute :suite_name, String
    attribute :test_type, String
    attribute :case_count, Integer
    attribute :last_run_result, String
    attribute :status, String
    reference_to TestProject
    attribute :cases, list_of(TestCase)

    value_object "TestCase" do
      attribute :case_name, String
      attribute :expected_result, String
      attribute :priority, String
    end

    command "DefineTestSuite" do
      role "QAEngineer"
      description "Create a test suite grouping related test cases"
      attribute :suite_name, String
      attribute :test_type, String
      reference_to(TestProject)
      emits "TestSuiteDefined"
      then_set :status, to: "active"
    end

    command "ExecuteTestSuite" do
      description "Run all test cases in a suite against a build"
      reference_to(TestSuite)
      attribute :build_id, String
      emits "TestSuiteExecuted"
    end

    command "RetireTestSuite" do
      description "Deactivate an obsolete test suite"
      reference_to(TestSuite)
      given("suite is inactive") { status == "active" }
      emits "TestSuiteRetired"
    end
  end

  aggregate "Bug", "A defect found during testing" do
    attribute :bug_id, String
    attribute :title, String
    attribute :description, String
    attribute :severity, String
    attribute :assigned_to, String
    attribute :status, String
    reference_to TestSuite
    attribute :reproductions, list_of(Reproduction)

    value_object "Reproduction" do
      attribute :step, String
      attribute :expected, String
      attribute :actual, String
    end

    command "FileBug" do
      role "QAEngineer"
      description "Report a defect discovered during test execution"
      attribute :bug_id, String
      attribute :title, String
      attribute :description, String
      attribute :severity, String
      reference_to(TestSuite)
      emits "BugFiled"
    end

    command "AssignBug" do
      description "Route a bug to a developer for fixing"
      reference_to(Bug)
      attribute :assigned_to, String
      emits "BugAssigned"
      then_set :status, to: "in_progress"
    end

    command "CloseBug" do
      description "Verify a fix and close the bug"
      reference_to(Bug)
      given("bug is in progress") { status == "in_progress" }
      emits "BugClosed"
    end
  end

  aggregate "TestEnvironment", "An isolated runtime for executing tests" do
    attribute :env_name, String
    attribute :platform, String
    attribute :browser_version, String
    attribute :os_version, String
    attribute :status, String
    attribute :config, list_of(ConfigParam)

    value_object "ConfigParam" do
      attribute :key, String
      attribute :value, String
      attribute :scope, String
    end

    command "SetupEnvironment" do
      role "DevOpsEngineer"
      description "Spin up a test environment with specified configuration"
      attribute :env_name, String
      attribute :platform, String
      attribute :browser_version, String
      attribute :os_version, String
      emits "EnvironmentSetUp"
      then_set :status, to: "idle"
    end

    command "TeardownEnvironment" do
      description "Destroy a test environment after use"
      reference_to(TestEnvironment)
      given("environment is idle") { status == "idle" }
      emits "EnvironmentTornDown"
    end

    command "LockEnvironment" do
      description "Reserve an environment for exclusive use during a test run"
      reference_to(TestEnvironment)
      emits "EnvironmentLocked"
    end
  end

  aggregate "Release", "A software version candidate gated by QA sign-off" do
    attribute :release_version, String
    attribute :branch_name, String
    attribute :build_id, String
    attribute :bugs_open, Integer
    attribute :status, String
    reference_to TestProject

    specification "ReleaseClear" do
      satisfied_by { bugs_open == 0 }
    end

    value_object "SignOff" do
      attribute :approver, String
      attribute :approved_at, String
      attribute :scope, String
    end

    command "CandidateRelease" do
      role "ReleaseManager"
      description "Propose a build as a release candidate"
      attribute :release_version, String
      attribute :branch_name, String
      attribute :build_id, String
      reference_to(TestProject)
      emits "ReleaseCandidated"
    end

    command "ApproveRelease" do
      description "Sign off on a release after all tests pass"
      reference_to(Release)
      given("no open bugs") { bugs_open == 0 }
      emits "ReleaseApproved"
    end

    command "BlockRelease" do
      description "Hold a release due to critical bugs"
      reference_to(Release)
      attribute :block_reason, String
      emits "ReleaseBlocked"
    end
  end

  lifecycle "QAGating" do
    state "project_created"
    state "suite_defined"
    state "environment_ready"
    state "executing"
    state "bugs_triaged"
    state "release_candidate"
    state "approved"

    transition from: "project_created", to: "suite_defined", on: "TestSuiteDefined"
    transition from: "suite_defined", to: "environment_ready", on: "EnvironmentSetUp"
    transition from: "environment_ready", to: "executing", on: "TestSuiteExecuted"
    transition from: "executing", to: "bugs_triaged", on: "BugFiled"
    transition from: "bugs_triaged", to: "release_candidate", on: "BugClosed"
    transition from: "release_candidate", to: "approved", on: "ReleaseApproved"
  end

  policy "TestSuiteDefinedSetupEnv" do
    on "TestSuiteDefined"
    trigger "SetupEnvironment"
  end

  policy "EnvironmentSetUpLockEnv" do
    on "EnvironmentSetUp"
    trigger "LockEnvironment"
  end

  policy "EnvironmentLockedExecuteSuite" do
    on "EnvironmentLocked"
    trigger "ExecuteTestSuite"
  end

  policy "TestSuiteExecutedFileBug" do
    on "TestSuiteExecuted"
    trigger "FileBug"
  end

  policy "BugFiledBlockRelease" do
    on "BugFiled"
    trigger "BlockRelease"
  end

  policy "BugClosedCandidateRelease" do
    on "BugClosed"
    trigger "CandidateRelease"
  end

  policy "AssignBugOnFile" do
    on "BugFiled"
    trigger "AssignBug"
  end

  policy "TeardownOnSuiteExecuted" do
    on "TestSuiteExecuted"
    trigger "TeardownEnvironment"
  end

end
