Hecks.behaviors "SEOAgency" do
  vision "Behavioral tests for the SEOAgency domain — exercises every command and query in memory"

  # ── Client aggregate ──────────────────────────────────────────

  test "SignClient sets client_name + website_url + industry + contact_email + plan_tier" do
    tests "SignClient", on: "Client"
    input  client_name: "sample", website_url: "sample", industry: "sample", contact_email: "sample", plan_tier: "sample"
    expect status: "active"
  end

  test "SignClient cascades through policy chain" do
    tests "SignClient", on: "Client", kind: :cascade
    setup  "RunAudit", audit_id: "sample", audit_type: "sample", pages_crawled: 1
    input  client_name: "sample", website_url: "sample", industry: "sample", contact_email: "sample", plan_tier: "sample"
    expect emits: ["ClientSigned", "AuditRun"]
  end

  test "PauseEngagement runs" do
    tests "PauseEngagement", on: "Client"
    setup  "SignClient", client_name: "sample", website_url: "sample", industry: "sample", contact_email: "sample", plan_tier: "sample"
    expect ok: "true"
  end

  test "TerminateClient runs" do
    tests "TerminateClient", on: "Client"
    setup  "SignClient", client_name: "sample", website_url: "sample", industry: "sample", contact_email: "sample", plan_tier: "sample"
    expect ok: "true"
  end


  # ── Keyword aggregate ──────────────────────────────────────────

  test "TargetKeyword sets phrase + search_volume + difficulty_score + intent_type" do
    tests "TargetKeyword", on: "Keyword"
    setup  "SignClient", client_name: "sample", website_url: "sample", industry: "sample", contact_email: "sample", plan_tier: "sample"
    input  phrase: "sample", search_volume: 1, difficulty_score: 1.0, intent_type: "sample"
    expect ok: "true"
  end

  test "TargetKeyword cascades through policy chain" do
    tests "TargetKeyword", on: "Keyword", kind: :cascade
    setup  "SignClient", client_name: "sample", website_url: "sample", industry: "sample", contact_email: "sample", plan_tier: "sample"
    setup  "AcquireBacklink", backlink_id: "sample", source_url: "sample", target_url: "sample", domain_authority: 1.0, anchor_text: "sample"
    setup  "GenerateReport", report_id: "sample", period: "sample"
    input  phrase: "sample", search_volume: 1, difficulty_score: 1.0, intent_type: "sample"
    expect emits: ["KeywordTargeted", "BacklinkAcquired", "RankingRecorded", "ReportGenerated", "ReportDelivered"]
  end

  test "RecordRanking sets position + search_engine" do
    tests "RecordRanking", on: "Keyword"
    setup  "TargetKeyword", phrase: "sample", search_volume: 1, difficulty_score: 1.0, intent_type: "sample"
    input  position: 1, search_engine: "sample"
    expect ok: "true"
  end

  test "RecordRanking cascades through policy chain" do
    tests "RecordRanking", on: "Keyword", kind: :cascade
    setup  "TargetKeyword", phrase: "sample", search_volume: 1, difficulty_score: 1.0, intent_type: "sample"
    setup  "GenerateReport", report_id: "sample", period: "sample"
    setup  "SignClient", client_name: "sample", website_url: "sample", industry: "sample", contact_email: "sample", plan_tier: "sample"
    input  position: 1, search_engine: "sample"
    expect emits: ["RankingRecorded", "ReportGenerated", "ReportDelivered"]
  end

  test "DropKeyword runs" do
    tests "DropKeyword", on: "Keyword"
    setup  "TargetKeyword", phrase: "sample", search_volume: 1, difficulty_score: 1.0, intent_type: "sample"
    expect ok: "true"
  end


