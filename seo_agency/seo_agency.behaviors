  test "FinalizeAudit cascades through policy chain" do
    tests "FinalizeAudit", on: "SiteAudit", kind: :cascade
    setup  "TargetKeyword", phrase: "sample", search_volume: 1, difficulty_score: 1.0, intent_type: "sample"
