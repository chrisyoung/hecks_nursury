  end

  test "GenerateReport cascades through policy chain" do
    tests "GenerateReport", on: "RankingReport", kind: :cascade
    setup  "SignClient", client_name: "sample", website_url: "sample", industry: "sample", contact_email: "sample", plan_tier: "sample"
    input  report_id: "sample", period: "sample"
