  end

  test "DeliverReport runs" do
    tests "DeliverReport", on: "RankingReport"
    setup  "GenerateReport", report_id: "sample", period: "sample"
    expect ok: "true"
  end

  test "ArchiveReport runs" do
    tests "ArchiveReport", on: "RankingReport"
    setup  "GenerateReport", report_id: "sample", period: "sample"
    expect ok: "true"
