    fixture "WeatherForecast2", region: "Caribbean Waters", wind_speed_knots: 12.0, wave_height_meters: 2.1, visibility_nm: 15.0, storm_warning: "tropical_depression", valid_from: "2026-04-13T00:00:00Z", valid_until: "2026-04-14T12:00:00Z", status: "expired"
  end
  aggregate "Vessel" do
    fixture "Queen_Elizabeth_", name: "Queen Elizabeth", vessel_type: "Cruise Ship", length_meters: 294.0, fuel_capacity_tons: 3500.0, current_fuel_tons: 3150.0, max_speed_knots: 21.5, status: "underway"
