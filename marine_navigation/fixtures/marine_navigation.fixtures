    fixture "FuelLog2", vessel_name: "Northern Star", fuel_burned_tons: 52.0, distance_traveled_nm: 180.0, efficiency_nm_per_ton: 3.46, timestamp: "2026-04-14T06:00:00Z", status: "flagged"
