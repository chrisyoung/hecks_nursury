Hecks.behaviors "MaterialsScience" do
  vision "Behavioral tests for the MaterialsScience domain — exercises every command and query in memory"

  # ── Crystal aggregate ──────────────────────────────────────────

  test "GrowCrystal sets name + crystal_system + temperature + growth_rate" do
    tests "GrowCrystal", on: "Crystal"
    input  name: "sample", crystal_system: "sample", temperature: 1.0, growth_rate: 1.0
    expect name: "sample", crystal_system: "sample", status: "nucleating"
  end

  test "DefineUnitCell sets a + b + c + alpha + beta + gamma" do
    tests "DefineUnitCell", on: "Crystal"
    setup  "GrowCrystal", name: "sample", crystal_system: "sample", temperature: 1.0, growth_rate: 1.0
    input  a: 1.0, b: 1.0, c: 1.0, alpha: 1.0, beta: 1.0, gamma: 1.0
    expect status: "growing"
  end

  test "ClassifySymmetry sets space_group + symmetry_class" do
    tests "ClassifySymmetry", on: "Crystal"
    setup  "GrowCrystal", name: "sample", crystal_system: "sample", temperature: 1.0, growth_rate: 1.0
    setup  "DefineUnitCell", a: 1.0, b: 1.0, c: 1.0, alpha: 1.0, beta: 1.0, gamma: 1.0
    input  space_group: "sample", symmetry_class: "sample"
    expect space_group: "sample", symmetry_class: "sample", status: "crystallized"
  end

  test "IntroduceDefect sets defect_type + defect_density" do
    tests "IntroduceDefect", on: "Crystal"
    setup  "GrowCrystal", name: "sample", crystal_system: "sample", temperature: 1.0, growth_rate: 1.0
    setup  "DefineUnitCell", a: 1.0, b: 1.0, c: 1.0, alpha: 1.0, beta: 1.0, gamma: 1.0
    setup  "ClassifySymmetry", space_group: "sample", symmetry_class: "sample"
    input  defect_type: "sample", defect_density: 1.0
    expect defect_type: "sample", defect_density: 1.0
  end

  test "AnnealCrystal sets anneal_temperature + cooling_rate" do
    tests "AnnealCrystal", on: "Crystal"
    setup  "GrowCrystal", name: "sample", crystal_system: "sample", temperature: 1.0, growth_rate: 1.0
    setup  "DefineUnitCell", a: 1.0, b: 1.0, c: 1.0, alpha: 1.0, beta: 1.0, gamma: 1.0
    setup  "ClassifySymmetry", space_group: "sample", symmetry_class: "sample"
    input  anneal_temperature: 1.0, cooling_rate: 1.0
    expect status: "annealed"
  end


  # ── Material aggregate ──────────────────────────────────────────

  test "ClassifyMaterial sets name + material_class" do
    tests "ClassifyMaterial", on: "Material"
    input  name: "sample", material_class: "sample"
    expect name: "sample", material_class: "sample"
  end

  test "MeasureDensity sets density" do
    tests "MeasureDensity", on: "Material"
    setup  "ClassifyMaterial", name: "sample", material_class: "sample"
    input  density: 1.0
    expect density: 1.0
  end

  test "TestHardness sets hardness + scale" do
    tests "TestHardness", on: "Material"
    setup  "ClassifyMaterial", name: "sample", material_class: "sample"
    input  hardness: 1.0, scale: "sample"
    expect hardness: 1.0
  end

  test "DetermineComposition runs" do
    tests "DetermineComposition", on: "Material"
    setup  "ClassifyMaterial", name: "sample", material_class: "sample"
    expect ok: "true"
  end

  test "CharacterizeMicrostructure sets microstructure" do
    tests "CharacterizeMicrostructure", on: "Material"
    setup  "ClassifyMaterial", name: "sample", material_class: "sample"
    input  microstructure: "sample"
    expect microstructure: "sample"
  end


  # ── PhaseTransition aggregate ──────────────────────────────────────────

  test "HeatMaterial sets material_name + temperature + pressure" do
    tests "HeatMaterial", on: "PhaseTransition"
    input  material_name: "sample", temperature: 1.0, pressure: 1.0
    expect material_name: "sample", temperature: 1.0, pressure: 1.0, status: "solid"
  end

  test "HeatMaterial cascades through policy chain" do
    tests "HeatMaterial", on: "PhaseTransition", kind: :cascade
    input  material_name: "sample", temperature: 1.0, pressure: 1.0
    expect emits: ["MaterialHeated", "TransitionTriggered", "MaterialQuenched"]
  end

  test "CoolMaterial sets temperature + cooling_rate" do
    tests "CoolMaterial", on: "PhaseTransition"
    setup  "HeatMaterial", material_name: "sample", temperature: 1.0, pressure: 1.0
    input  temperature: 1.0, cooling_rate: 1.0
    expect temperature: 1.0
  end

  test "CoolMaterial cascades through policy chain" do
    tests "CoolMaterial", on: "PhaseTransition", kind: :cascade
    setup  "HeatMaterial", material_name: "sample", temperature: 1.0, pressure: 1.0
    setup  "GrowCrystal", name: "sample", crystal_system: "sample", temperature: 1.0, growth_rate: 1.0
    input  temperature: 1.0, cooling_rate: 1.0
    expect emits: ["MaterialCooled", "CrystalGrown"]
  end

  test "IdentifyPhase sets current_phase" do
    tests "IdentifyPhase", on: "PhaseTransition"
    setup  "HeatMaterial", material_name: "sample", temperature: 1.0, pressure: 1.0
    input  current_phase: "sample"
    expect current_phase: "sample"
  end

  test "MapPhaseDiagram sets transition_type" do
    tests "MapPhaseDiagram", on: "PhaseTransition"
    setup  "HeatMaterial", material_name: "sample", temperature: 1.0, pressure: 1.0
    input  transition_type: "sample"
    expect transition_type: "sample"
  end

  test "TriggerTransition sets target_phase" do
    tests "TriggerTransition", on: "PhaseTransition"
    setup  "HeatMaterial", material_name: "sample", temperature: 1.0, pressure: 1.0
    input  target_phase: "sample"
    expect target_phase: "sample", status: "melting"
  end

  test "TriggerTransition cascades through policy chain" do
    tests "TriggerTransition", on: "PhaseTransition", kind: :cascade
    setup  "HeatMaterial", material_name: "sample", temperature: 1.0, pressure: 1.0
    input  target_phase: "sample"
    expect emits: ["TransitionTriggered", "MaterialQuenched"]
  end

  test "Quench runs" do
    tests "Quench", on: "PhaseTransition"
    setup  "HeatMaterial", material_name: "sample", temperature: 1.0, pressure: 1.0
    setup  "TriggerTransition", target_phase: "sample"
    expect status: "solid"
  end


  # ── Alloy aggregate ──────────────────────────────────────────

  test "FormAlloy sets name + base_metal" do
    tests "FormAlloy", on: "Alloy"
    input  name: "sample", base_metal: "sample"
    expect name: "sample", base_metal: "sample"
  end

  test "FormAlloy cascades through policy chain" do
    tests "FormAlloy", on: "Alloy", kind: :cascade
    input  name: "sample", base_metal: "sample"
    expect emits: ["AlloyFormed", "TensileStrengthTested"]
  end

  test "MixComponents sets element + weight_percent" do
    tests "MixComponents", on: "Alloy"
    setup  "FormAlloy", name: "sample", base_metal: "sample"
    input  element: "sample", weight_percent: 1.0
    expect ok: "true"
  end

  test "MeasureSolubility sets solubility + temperature" do
    tests "MeasureSolubility", on: "Alloy"
    setup  "FormAlloy", name: "sample", base_metal: "sample"
    input  solubility: 1.0, temperature: 1.0
    expect solubility: 1.0
  end

  test "HeatTreat sets heat_treatment + temperature + hold_time" do
    tests "HeatTreat", on: "Alloy"
    setup  "FormAlloy", name: "sample", base_metal: "sample"
    input  heat_treatment: "sample", temperature: 1.0, hold_time: 1.0
    expect heat_treatment: "sample"
  end

  test "TestTensileStrength sets tensile_strength + yield_strength" do
    tests "TestTensileStrength", on: "Alloy"
    setup  "FormAlloy", name: "sample", base_metal: "sample"
    input  tensile_strength: 1.0, yield_strength: 1.0
    expect tensile_strength: 1.0, yield_strength: 1.0
  end

  test "Temper sets temper_temperature + duration" do
    tests "Temper", on: "Alloy"
    setup  "FormAlloy", name: "sample", base_metal: "sample"
    input  temper_temperature: 1.0, duration: 1.0
    expect ok: "true"
  end


  # ── Polymer aggregate ──────────────────────────────────────────

  test "Polymerize sets name + monomer + degree_of_polymerization" do
    tests "Polymerize", on: "Polymer"
    input  name: "sample", monomer: "sample", degree_of_polymerization: 1
    expect name: "sample", monomer: "sample", degree_of_polymerization: 1, status: "polymerizing"
  end

  test "Crosslink sets crosslink_density + crosslinker" do
    tests "Crosslink", on: "Polymer"
    setup  "Polymerize", name: "sample", monomer: "sample", degree_of_polymerization: 1
    setup  "MeasureMolecularWeight", molecular_weight: 1.0, method: "sample"
    input  crosslink_density: 1.0, crosslinker: "sample"
    expect crosslink_density: 1.0, status: "crosslinked"
  end

  test "MeasureMolecularWeight sets molecular_weight + method" do
    tests "MeasureMolecularWeight", on: "Polymer"
    setup  "Polymerize", name: "sample", monomer: "sample", degree_of_polymerization: 1
    input  molecular_weight: 1.0, method: "sample"
    expect molecular_weight: 1.0, status: "polymer"
  end

  test "TestElasticity sets elasticity + strain_rate" do
    tests "TestElasticity", on: "Polymer"
    setup  "Polymerize", name: "sample", monomer: "sample", degree_of_polymerization: 1
    input  elasticity: 1.0, strain_rate: 1.0
    expect elasticity: 1.0
  end

  test "Degrade sets degradation_mechanism + mass_loss" do
    tests "Degrade", on: "Polymer"
    setup  "Polymerize", name: "sample", monomer: "sample", degree_of_polymerization: 1
    setup  "MeasureMolecularWeight", molecular_weight: 1.0, method: "sample"
    setup  "Crosslink", crosslink_density: 1.0, crosslinker: "sample"
    input  degradation_mechanism: "sample", mass_loss: 1.0
    expect status: "degraded"
  end

  test "Vulcanize sets sulfur_content + temperature" do
    tests "Vulcanize", on: "Polymer"
    setup  "Polymerize", name: "sample", monomer: "sample", degree_of_polymerization: 1
    setup  "MeasureMolecularWeight", molecular_weight: 1.0, method: "sample"
    input  sulfur_content: 1.0, temperature: 1.0
    expect status: "crosslinked"
  end


  # ── Composite aggregate ──────────────────────────────────────────

  test "LayupComposite sets name + matrix_material + reinforcement" do
    tests "LayupComposite", on: "Composite"
    input  name: "sample", matrix_material: "sample", reinforcement: "sample"
    expect name: "sample", matrix_material: "sample", reinforcement: "sample", status: "laid_up"
