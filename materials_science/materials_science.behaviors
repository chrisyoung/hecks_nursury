  test "MeasureThermalConductivity sets thermal_conductivity" do
    tests "MeasureThermalConductivity", on: "Ceramic"
    setup  "SinterCeramic", name: "sample", ceramic_type: "sample", sinter_temperature: 1.0, hold_time: 1.0
