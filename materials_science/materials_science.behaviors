  # ── Semiconductor aggregate ──────────────────────────────────────────

  test "GrowWafer sets name + base_material + diameter" do
    tests "GrowWafer", on: "Semiconductor"
    input  name: "sample", base_material: "sample", diameter: 1.0
    expect name: "sample", base_material: "sample", status: "intrinsic"
  end

  test "DopeSemiconductor sets dopant + dopant_concentration + conductivity_type" do
    tests "DopeSemiconductor", on: "Semiconductor"
    setup  "GrowWafer", name: "sample", base_material: "sample", diameter: 1.0
    input  dopant: "sample", dopant_concentration: 1.0, conductivity_type: "sample"
    expect dopant: "sample", dopant_concentration: 1.0, conductivity_type: "sample", status: "doped"
  end

  test "MeasureBandGap sets band_gap" do
    tests "MeasureBandGap", on: "Semiconductor"
    setup  "GrowWafer", name: "sample", base_material: "sample", diameter: 1.0
