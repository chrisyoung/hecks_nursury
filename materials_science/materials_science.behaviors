  # ── Stress aggregate ──────────────────────────────────────────

  test "ApplyStress sets material_name + stress_type + magnitude" do
    tests "ApplyStress", on: "Stress"
    input  material_name: "sample", stress_type: "sample", magnitude: 1.0
    expect material_name: "sample", stress_type: "sample"
  end

  test "MeasureStrain sets strain + gauge_length" do
    tests "MeasureStrain", on: "Stress"
    setup  "ApplyStress", material_name: "sample", stress_type: "sample", magnitude: 1.0
    input  strain: 1.0, gauge_length: 1.0
